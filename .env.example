# ── LLM settings ──────────────────────────────────────────────────────────────
# Provider: "ollama" (local, free) or "anthropic" (paid API)
LLM__PROVIDER=ollama

# Model name
#   Ollama:    gemma4:e4b  (recommended — fast, good quality)
#   Anthropic: claude-haiku-4-5-20251001
LLM__MODEL=gemma4:e4b

# Ollama base URL (ignored when provider=anthropic)
LLM__BASE_URL=http://localhost:11434/v1

# API key
#   Ollama:    leave as "ollama" (no real key needed)
#   Anthropic: sk-ant-...
LLM__API_KEY=ollama

# Max tokens per LLM request (8192 recommended for reasoning models)
LLM__MAX_TOKENS=8192

# ── Crawler settings ───────────────────────────────────────────────────────────
# Request delay range in seconds (min, max)
CRAWLER__MIN_DELAY=1.0
CRAWLER__MAX_DELAY=3.0

# Custom User-Agent (optional — may help with some Cloudflare-protected sites)
# CRAWLER__USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
